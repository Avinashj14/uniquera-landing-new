# Copy to `api/.env` on Hostinger (same folder as uniquera-form-submit.php).

# --- Hostinger mailbox (recommended) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=noreply@uniqueraclinic.com
SMTP_PASS=your-mailbox-password

# Who receives consultation emails (comma-separated for multiple)
SMTP_TO=uniquera@uniqueraclinic.com
# Optional copies:
# SMTP_CC=team@uniqueraclinic.com
# SMTP_BCC=backup@uniqueraclinic.com

# Must match SMTP_USER on Hostinger (script forces this if different)
MAIL_FROM=noreply@uniqueraclinic.com
MAIL_FROM_NAME=Uniquera Clinic

# If port 587 + tls fails, try 465 + ssl (see above)
# SMTP_VERIFY_SSL=false

# Debug: shows SMTP error in JSON + sent_to address
FORM_DEBUG=false

# Optional: POST to /api/mail-test.php with {"key":"..."} to send a test email
# MAIL_TEST_KEY=change-me-to-a-long-random-string
