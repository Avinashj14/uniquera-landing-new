# Copy to `api/.env` on your Hostinger server (same folder as uniquera-form-submit.php).
# Required for form submission emails.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password-or-app-password

# Where consultation submissions are delivered
SMTP_TO=uniquera@uniqueraclinic.com

MAIL_FROM=your-smtp-user@example.com
MAIL_FROM_NAME=Uniquera Clinic

# Set to true only while debugging (returns mail error details in JSON)
FORM_DEBUG=false
